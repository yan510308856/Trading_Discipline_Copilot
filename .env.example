# Keep the real key in .env. Never commit .env.
FINNHUB_API_KEY=replace_with_your_finnhub_key
EMAIL_NOTIFICATIONS_ENABLED=false
ALERT_RECIPIENT_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
PRICE_ALERT_MONITOR_ENABLED=false
PRICE_ALERT_POLL_SECONDS=60
# Monitor health is held in the local backend process and resets on restart.
PRICE_ALERT_RETRY_LIMIT=3
APP_BASE_URL=http://localhost:3000
